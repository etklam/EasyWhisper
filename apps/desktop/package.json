{
  "name": "@easywhisper/desktop",
  "version": "0.1.0-alpha",
  "private": true,
  "type": "module",
  "description": "EASYWhisper desktop app",
  "author": "EASYWhisper",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "stage:mac:whisper": "node ./scripts/stage_mac_whisper_runtime.mjs",
    "stage:win:whisper": "node ./scripts/stage_windows_whisper_runtime.mjs",
    "package:mac:dir": "pnpm run stage:mac:whisper && pnpm run build && electron-builder --mac dir",
    "package:mac": "pnpm run stage:mac:whisper && pnpm run build && electron-builder --mac dir dmg",
    "package:win:dir": "node ./scripts/clean_windows_release.mjs && pnpm run build && electron-builder --win dir",
    "package:win": "node ./scripts/clean_windows_release.mjs && pnpm run build && electron-builder --win nsis",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@easywhisper/shared": "workspace:*",
    "@easywhisper/ui": "workspace:*",
    "electron-store": "^10.0.0",
    "naive-ui": "^2.41.1",
    "pinia": "^3.0.3",
    "vue": "^3.5.13",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.5.1",
    "yauzl": "^3.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/ui": "^3.0.8",
    "@vue/test-utils": "^2.4.6",
    "electron": "^35.0.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "happy-dom": "^17.1.7",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.8",
    "vue-tsc": "^2.2.8"
  },
  "build": {
    "appId": "com.fosswhisper.desktop",
    "productName": "EASYWhisper",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/mac",
        "to": "mac",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/versions.json",
        "to": "versions.json"
      },
      {
        "from": "resources/win",
        "to": "win",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dir",
        "dmg"
      ]
    },
    "win": {
      "target": [
        "dir",
        "nsis"
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}"
    }
  }
}
